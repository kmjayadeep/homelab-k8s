{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "kubernetes": {
    "managerFilePatterns": ["/clusters/.+\\.yaml$/"]
  },
  "packageRules": [
    {
      "matchPackageNames": ["ghcr.io/fluxcd/*"],
      "groupName": "fluxcd controllers",
      "groupSlug": "fluxcd-controllers"
    }
  ]
}
